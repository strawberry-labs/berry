{
  "name": "@berry/acp-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "berry-acp": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@berry/host": "workspace:*",
    "@berry/shared": "workspace:*",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
