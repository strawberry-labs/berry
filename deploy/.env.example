POSTGRES_DB=berry
POSTGRES_USER=berry
POSTGRES_PASSWORD=replace-me

MINIO_ROOT_USER=berry
MINIO_ROOT_PASSWORD=replace-me
BERRY_ARTIFACT_S3_BUCKET=berry-artifacts
BERRY_ARTIFACT_S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
BERRY_FILE_MAX_UPLOAD_BYTES=1073741824
BERRY_FILE_MULTIPART_PART_SIZE=16777216
BERRY_FILE_PRESIGN_SECONDS=900

BERRY_API_PORT=3001
BERRY_WEB_PORT=3108
BERRY_DOMAIN=localhost
BERRY_FILES_DOMAIN=files.localhost
BERRY_WEB_PUBLIC_URL=http://localhost:3108
BERRY_MINIO_PORT=9000
BERRY_MINIO_CONSOLE_PORT=9001

# Public deployment model for API/web health, admin fixtures, and Helm parity.
# Valid values: managed, dedicated, self-hosted.
DEPLOYMENT_MODE=self-hosted

# Local and production deployments use the same one-time owner setup.
# Change the email and setup key before sharing this instance with anyone.
BERRY_AUTH_MODE=better-auth
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BERRY_AUTH_BASE_URL=http://localhost:3001
BERRY_AUTH_TRUSTED_ORIGINS=http://localhost:3108,http://127.0.0.1:3108
BERRY_AUTH_SIGNUP_ENABLED=false
BERRY_SETUP_OWNER_EMAIL=founder@local.test
BERRY_SETUP_TOKEN=berry-local-owner-setup-key-change-me-before-sharing
BERRY_AUTH_MAX_USERS=10
BERRY_AUTH_ALLOWED_EMAILS=
BERRY_AUTH_ALLOWED_EMAIL_DOMAINS=
BERRY_AUTH_ALLOW_OPEN_SIGNUP=false
BERRY_SCIM_BEARER_TOKEN=

# Budgets reserve before model/sandbox spend and fail closed when Redis health is down.
BERRY_BUDGETS_ENABLED=true
BERRY_BUDGET_FAIL_CLOSED=true
BERRY_BUDGET_SANDBOX_CREATE_ESTIMATE_MICROS=50
BERRY_BUDGET_SANDBOX_EXEC_ESTIMATE_MICROS=25

# Billing defaults to no external dependency for self-host. Use stripe for managed/dedicated cloud.
BERRY_BILLING_PROVIDER=none
STRIPE_SECRET_KEY=
STRIPE_BILLING_METER_EVENT_NAME=
STRIPE_CREDIT_PRICE_ID=
BERRY_BILLING_STRIPE_API_BASE_URL=https://api.stripe.com

# Comma-separated key_id:secret pairs accepted by the usage ingest endpoint.
# Replace before wiring live Router or sandbox usage webhooks.
BERRY_USAGE_SIGNING_SECRETS=fixture:replace-me-usage-secret
BERRY_USAGE_SIGNATURE_MAX_SKEW_MS=300000

# Ed25519 key used to sign org berry-policy.json versions.
# Generate and store offline before publishing managed policy:
#   openssl genpkey -algorithm ED25519 -out berry-policy-ed25519.pem
BERRY_POLICY_SIGNING_KEY_ID=self-host-2026
BERRY_POLICY_SIGNING_PRIVATE_KEY_PEM=

# Desktop/CLI org login client configuration. These are consumed by berry-host/CLI,
# not by the compose API container unless you explicitly run desktop/CLI from this env.
BERRY_PLATFORM_BASE_URL=http://localhost:3001
BERRY_PLATFORM_OAUTH_CLIENT_ID=berry-cli
BERRY_PLATFORM_AUTHORIZE_URL=http://localhost:3001/oauth/authorize
BERRY_PLATFORM_TOKEN_URL=http://localhost:3001/oauth/token
BERRY_PLATFORM_SESSION_URL=http://localhost:3001/v1/me/org-session
BERRY_PLATFORM_REDIRECT_URI=berry://platform/oauth/callback
BERRY_PLATFORM_OAUTH_SCOPE=openid email profile berry.org
BERRY_PLATFORM_USAGE_SIGNING_KEY_ID=fixture
BERRY_PLATFORM_USAGE_SIGNING_SECRET=replace-me-usage-secret

# Optional S3-compatible destination for audit SIEM drops.
# Webhook destinations are configured per org through /v1/orgs/:tenantId/audit/exports.
BERRY_AUDIT_S3_ENDPOINT=http://minio:9000
BERRY_AUDIT_S3_BUCKET=berry-audit
BERRY_AUDIT_S3_ACCESS_KEY_ID=berry
BERRY_AUDIT_S3_SECRET_ACCESS_KEY=replace-me
BERRY_AUDIT_S3_PREFIX=audit

# Set live to use provider credentials passed by the web/API request.
BERRY_API_MODEL_MODE=fixture

# Local compose uses a contract fixture without a privileged Docker socket.
# Production calls E2B directly from the private API container.
BERRY_SANDBOX_PROVIDER=fixture
BERRY_SANDBOX_IMAGE=node:22-bookworm
BERRY_SANDBOX_DOCKER_IMAGE_ALLOWLIST=node:22-bookworm,node:22-bookworm-slim

# Direct E2B cloud provider (used when BERRY_SANDBOX_PROVIDER=e2b).
E2B_API_KEY=
BERRY_E2B_TEMPLATE_ID=base
BERRY_E2B_DOMAIN=
BERRY_E2B_REQUEST_TIMEOUT_MS=60000
BERRY_E2B_KEEP_MEMORY_ON_PAUSE=false
BERRY_E2B_ESTIMATED_HOURLY_COST_MICROS=
BERRY_E2B_MINIMUM_EXEC_COST_MICROS=0
BERRY_SANDBOX_TTL_SECONDS=900

# Commercial/Router sandbox provider seam.
BERRY_ROUTER_URL=
BERRY_ROUTER_SERVICE_TOKEN=
BERRY_SANDBOX_COMMERCIAL_PROVIDER=

BERRY_WEB_API_BASE_URL=http://localhost:3001
# Optional server-only URL used by web SSR to avoid a public network round trip.
BERRY_WEB_API_INTERNAL_URL=http://localhost:3001
BERRY_WEB_WORKSPACE_ID=self-host
BERRY_WEB_WORKSPACE_PATH=/workspace
BERRY_WEB_SANDBOX_TERMINAL_WS_URL=
