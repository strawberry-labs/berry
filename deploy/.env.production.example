# Public host. DNS A/AAAA must point here before Caddy requests TLS.
BERRY_DOMAIN=aesg-v2.berry.me
BERRY_FILES_DOMAIN=files.aesg-v2.berry.me
DEPLOYMENT_MODE=self-hosted
BERRY_WEB_API_BASE_URL=https://aesg-v2.berry.me
BERRY_AUTH_BASE_URL=https://aesg-v2.berry.me
BERRY_AUTH_TRUSTED_ORIGINS=https://aesg-v2.berry.me
BERRY_API_CORS_ORIGINS=https://aesg-v2.berry.me

# Generate the database, MinIO, and webhook values independently with
# `openssl rand -hex 32` (hex stays URL-safe in BERRY_DATABASE_URL). Generate
# BETTER_AUTH_SECRET with `openssl rand -base64 36`.
POSTGRES_DB=berry
POSTGRES_USER=berry
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_POSTGRES_PASSWORD
MINIO_ROOT_USER=berry-storage
MINIO_ROOT_PASSWORD=REPLACE_WITH_RANDOM_MINIO_PASSWORD
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
BETTER_AUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_36
BERRY_USAGE_SIGNING_SECRETS=router-prod:REPLACE_WITH_RANDOM_USAGE_WEBHOOK_SECRET

# Private, single-organization account policy. Keep an allow-list when signup is on.
BERRY_AUTH_MODE=better-auth
BERRY_AUTH_SIGNUP_ENABLED=false
BERRY_AUTH_MAX_USERS=10
BERRY_DEFAULT_ORG_MONTHLY_BUDGET_MICROS=100000000
BERRY_DEFAULT_USER_MONTHLY_BUDGET_MICROS=15000000
BERRY_AUTH_ALLOWED_EMAILS=owner@example.com,user2@example.com
BERRY_AUTH_ALLOWED_EMAIL_DOMAINS=
BERRY_AUTH_ALLOW_OPEN_SIGNUP=false
BERRY_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
BERRY_AUTH_RATE_LIMIT_MAX=30

# BerryRouter inference. The base URL should normally end in /v1.
BERRY_API_MODEL_MODE=live
BERRY_ROUTER_INFERENCE_BASE_URL=https://REPLACE_WITH_BERRYROUTER_HOST/v1
BERRY_ROUTER_API_KEY=REPLACE_WITH_BERRYROUTER_INFERENCE_KEY
BERRY_ROUTER_PROVIDER_ID=router
BERRY_ROUTER_PROVIDER_NAME=Berry Router
BERRY_ROUTER_CHAT_COMPLETIONS_PATH=/chat/completions
BERRY_ROUTER_COMPLETION_TRANSPORT=stream
BERRY_ROUTER_MODELS_PATH=/models
BERRY_ROUTER_DEFAULT_MODEL=REPLACE_WITH_KIMI_2_6_MODEL_ID
BERRY_CLOUD_MODEL_MAX_OUTPUT_TOKENS=4096
# Replace this entire value with one valid, single-line JSON array. Cost input/output
# values are USD per million tokens, numerically equal to micro-dollars per token.
BERRY_ROUTER_MODELS_JSON=[{"id":"REPLACE_WITH_KIMI_2_6_MODEL_ID","name":"Kimi 2.6","inputModalities":["text","image"],"outputModalities":["text"],"capabilities":{"tools":true,"vision":true,"reasoning":true,"cost":{"input":REPLACE_WITH_KIMI_INPUT_USD_PER_MILLION,"output":REPLACE_WITH_KIMI_OUTPUT_USD_PER_MILLION}}},{"id":"REPLACE_WITH_GLM_5_2_MODEL_ID","name":"GLM 5.2","inputModalities":["text","image"],"outputModalities":["text"],"capabilities":{"tools":true,"vision":true,"reasoning":true,"cost":{"input":REPLACE_WITH_GLM_INPUT_USD_PER_MILLION,"output":REPLACE_WITH_GLM_OUTPUT_USD_PER_MILLION}}}]

# BerryRouter image generation. Leave IMAGE_MODEL blank only if the feature should be disabled.
BERRY_ROUTER_IMAGE_GENERATIONS_PATH=/images/generations
BERRY_ROUTER_IMAGE_GENERATIONS_URL=
BERRY_ROUTER_IMAGE_MODEL=REPLACE_WITH_IMAGE_MODEL_ID
BERRY_ROUTER_IMAGE_RESPONSE_FORMAT=b64_json
BERRY_ROUTER_IMAGE_COST_MICROS=REPLACE_WITH_IMAGE_COST_IN_USD_MICROS

# E2B is called directly by the private API container. This key never reaches the browser.
BERRY_SANDBOX_PROVIDER=e2b
E2B_API_KEY=REPLACE_WITH_E2B_API_KEY
# `base` works for initial Node/Python testing. Use a reviewed custom template ID
# when you need pinned packages or a guaranteed CPU/RAM/disk shape.
BERRY_E2B_TEMPLATE_ID=base
BERRY_E2B_DOMAIN=
BERRY_E2B_REQUEST_TIMEOUT_MS=60000
BERRY_E2B_KEEP_MEMORY_ON_PAUSE=false
# Total selected-template price in USD micros/hour (for example, $0.10/hour = 100000).
BERRY_E2B_ESTIMATED_HOURLY_COST_MICROS=REPLACE_WITH_E2B_TEMPLATE_USD_MICROS_PER_HOUR
BERRY_E2B_MINIMUM_EXEC_COST_MICROS=1
BERRY_SANDBOX_IMAGE=base
BERRY_SANDBOX_CWD=/home/user/workspace
# The sandbox auto-pauses after 15 idle minutes and reconnects by session ID.
BERRY_SANDBOX_TTL_SECONDS=900
# These values drive Berry usage estimates; keep them aligned with the E2B template.
BERRY_SANDBOX_CPU_COUNT=2
BERRY_SANDBOX_MEMORY_MIB=4096
BERRY_SANDBOX_DISK_MIB=10240

# BerryCrawl MCP. The URL must be public HTTPS and the hostname must be in the allow-list.
BERRYCRAWL_API_KEY=REPLACE_WITH_BERRYCRAWL_KEY
BERRY_CLOUD_MCP_SERVERS_JSON=[{"id":"berrycrawl","name":"BerryCrawl","transport":"streamable-http","url":"https://REPLACE_WITH_BERRYCRAWL_HOST/mcp","credentialEnv":"BERRYCRAWL_API_KEY","enabled":true,"trusted":true}]
BERRY_CLOUD_NETWORK_EGRESS=on
BERRY_CLOUD_NETWORK_ALLOWED_DOMAINS=REPLACE_WITH_BERRYCRAWL_HOST,registry.npmjs.org,pypi.org,files.pythonhosted.org,github.com,api.github.com

# Registered hosted skills. Use a single-line JSON array; content is the full SKILL.md body.
BERRY_CLOUD_SKILLS_JSON=[{"name":"research","description":"Research with BerryCrawl and cite sources.","content":"Use the BerryCrawl MCP tools for web research. Cite every factual claim with its source URL.","enabled":true}]

# Budgets and worker.
BERRY_BUDGETS_ENABLED=true
BERRY_BUDGET_FAIL_CLOSED=true
BERRY_BUDGET_SANDBOX_CREATE_ESTIMATE_MICROS=50
# Reserve a conservative maximum command cost before execution; reconciliation uses
# the runtime-derived E2B estimate above.
BERRY_BUDGET_SANDBOX_EXEC_ESTIMATE_MICROS=REPLACE_WITH_CONSERVATIVE_E2B_EXEC_RESERVATION_MICROS
BERRY_WORKER_CONCURRENCY=4

# Private MinIO storage on this Hetzner server.
BERRY_OBJECT_STORAGE_MODE=minio
BERRY_ARTIFACT_S3_ENDPOINT=http://minio:9000
BERRY_ARTIFACT_S3_PUBLIC_ENDPOINT=https://files.aesg-v2.berry.me
BERRY_ARTIFACT_S3_REGION=us-east-1
BERRY_ARTIFACT_S3_BUCKET=berry-artifacts
BERRY_ARTIFACT_S3_ACCESS_KEY_ID=berry-storage
BERRY_ARTIFACT_S3_SECRET_ACCESS_KEY=REPLACE_WITH_THE_SAME_MINIO_PASSWORD
BERRY_ARTIFACT_S3_PREFIX=artifacts
BERRY_ARTIFACT_PUBLIC_BASE_URL=https://aesg-v2.berry.me/v1/artifacts
BERRY_FILE_MAX_UPLOAD_BYTES=1073741824
BERRY_FILE_MULTIPART_PART_SIZE=16777216
BERRY_FILE_PRESIGN_SECONDS=900
BERRY_AUDIT_S3_ENDPOINT=http://minio:9000
BERRY_AUDIT_S3_REGION=us-east-1
BERRY_AUDIT_S3_BUCKET=berry-audit
BERRY_AUDIT_S3_ACCESS_KEY_ID=berry-storage
BERRY_AUDIT_S3_SECRET_ACCESS_KEY=REPLACE_WITH_THE_SAME_MINIO_PASSWORD
BERRY_AUDIT_S3_PREFIX=audit

# Billing is deliberately disabled for this private client deployment.
BERRY_BILLING_PROVIDER=none
STRIPE_SECRET_KEY=
STRIPE_BILLING_METER_EVENT_NAME=
STRIPE_CREDIT_PRICE_ID=

# Optional enterprise integrations. Blank means disabled.
BERRY_SCIM_BEARER_TOKEN=
BERRY_POLICY_SIGNING_KEY_ID=aesg-v2-2026
BERRY_POLICY_SIGNING_PRIVATE_KEY_PEM=
BERRY_WEB_SANDBOX_TERMINAL_WS_URL=

# Loopback-only diagnostics; Caddy is the only public service.
BERRY_API_PORT=3001
BERRY_WEB_PORT=3108
BERRY_MINIO_PORT=9000
BERRY_MINIO_CONSOLE_PORT=9001
