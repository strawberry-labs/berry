{
  "name": "@berry/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --passWithNoTests",
    "tauri": "tauri",
    "package": "node ../../scripts/build-sidecars.mjs && node ../../scripts/render-tauri-release-config.mjs && tauri build --config src-tauri/target/tauri.release.generated.conf.json",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@berry/desktop-ui": "workspace:*",
    "@berry/shared": "workspace:*",
    "@berry/thread-ui": "workspace:*",
    "@fontsource/jetbrains-mono": "^5.0.21",
    "@fontsource/open-sans": "^5.0.28",
    "@fontsource/source-serif-4": "^5.0.19",
    "@lexical/react": "0.46.0",
    "@lobehub/icons-static-svg": "1.91.0",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-router": "^1.49.8",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "figma-squircle": "1.1.0",
    "lexical": "0.46.0",
    "lucide-react": "^0.468.0",
    "next-themes": "0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "10.1.0",
    "recharts": "3.8.0",
    "remark-gfm": "4.0.1",
    "shiki": "^4.3.1",
    "sonner": "2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
