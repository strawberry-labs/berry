{
  "name": "@berry/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 3108 --strictPort",
    "build": "node ../../scripts/prepare-web-build.mjs && vite build && node ../../scripts/verify-web-build-assets.mjs",
    "start": "srvx --prod -s ../client dist/server/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run src",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "1.2.4",
    "@berry/api-client": "workspace:*",
    "@berry/desktop-ui": "workspace:*",
    "@berry/shared": "workspace:*",
    "@berry/thread-ui": "workspace:*",
    "@fontsource/jetbrains-mono": "^5.0.21",
    "@fontsource/source-serif-4": "^5.0.19",
    "@lexical/react": "0.46.0",
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "docx-preview": "0.4.0",
    "jszip": "3.10.1",
    "lexical": "0.46.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "0.56.0",
    "next-themes": "0.4.6",
    "react": "^19.0.0",
    "react-data-grid": "7.0.0-beta.61",
    "react-dom": "^19.0.0",
    "react-photo-view": "1.2.1",
    "recharts": "3.8.0",
    "sonner": "2.0.7",
    "srvx": "0.11.21",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  }
