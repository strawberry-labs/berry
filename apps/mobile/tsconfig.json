{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true,
    "types": ["vitest/globals"]
  },
  "include": ["App.tsx", "index.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "nativewind-env.d.ts"]
}
